{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aura.dev/schemas/0.1/elements.schema.json",
  "title": "AURA Elements",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "id",
      "carrier_id",
      "bounds",
      "color",
      "opacity",
      "confidence",
      "residual",
      "lod",
      "chunk_id",
      "metadata",
      "confidence_map",
      "edit",
      "payload"
    ],
    "properties": {
      "id": {
        "type": "string",
        "minLength": 1
      },
      "carrier_id": {
        "type": "string",
        "minLength": 1
      },
      "bounds": {
        "$ref": "#/$defs/bounds"
      },
      "color": {
        "$ref": "#/$defs/vec3"
      },
      "opacity": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      },
      "confidence": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      },
      "normal": {
        "anyOf": [
          { "$ref": "#/$defs/vec3" },
          { "type": "null" }
        ]
      },
      "material_id": {
        "type": ["string", "null"]
      },
      "semantic_id": {
        "type": ["string", "null"]
      },
      "residual": {
        "type": "boolean"
      },
      "lod": {
        "type": "integer",
        "minimum": 0
      },
      "chunk_id": {
        "type": "string",
        "minLength": 1
      },
      "metadata": {
        "type": "object",
        "additionalProperties": {
          "type": "string"
        }
      },
      "confidence_map": {
        "type": "object",
        "additionalProperties": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "edit": {
        "type": "object",
        "additionalProperties": {
          "$ref": "#/$defs/json_value"
        }
      },
      "payload": {
        "anyOf": [
          {
            "type": "object",
            "maxProperties": 0
          },
          {
            "$ref": "#/$defs/surface_payload"
          },
          {
            "$ref": "#/$defs/volume_payload"
          },
          {
            "$ref": "#/$defs/beta_payload"
          },
          {
            "$ref": "#/$defs/gabor_payload"
          },
          {
            "$ref": "#/$defs/neural_payload"
          },
          {
            "$ref": "#/$defs/gaussian_payload"
          },
          {
            "$ref": "#/$defs/semantic_payload"
          }
        ]
      }
    }
  },
  "$defs": {
    "json_value": {
      "type": ["string", "number", "boolean", "null"]
    },
    "vec3": {
      "type": "array",
      "prefixItems": [
        { "type": "number" },
        { "type": "number" },
        { "type": "number" }
      ],
      "items": false,
      "minItems": 3,
      "maxItems": 3
    },
    "bounds": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min", "max"],
      "properties": {
        "min": { "$ref": "#/$defs/vec3" },
        "max": { "$ref": "#/$defs/vec3" }
      }
    },
    "matrix3": {
      "type": "array",
      "prefixItems": [
        { "$ref": "#/$defs/vec3" },
        { "$ref": "#/$defs/vec3" },
        { "$ref": "#/$defs/vec3" }
      ],
      "items": false,
      "minItems": 3,
      "maxItems": 3
    },
    "surface_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "normal", "thickness", "roughness"],
      "properties": {
        "type": { "const": "surface_cell" },
        "normal": { "$ref": "#/$defs/vec3" },
        "plane_point": { "$ref": "#/$defs/vec3" },
        "thickness": { "type": "number", "exclusiveMinimum": 0 },
        "roughness": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "volume_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "density", "phase_anisotropy"],
      "properties": {
        "type": { "const": "volume_cell" },
        "density": { "type": "number", "minimum": 0, "maximum": 1 },
        "phase_anisotropy": { "type": "number", "minimum": -1, "maximum": 1 }
      }
    },
    "beta_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "alpha", "beta", "support_radius"],
      "properties": {
        "type": { "const": "beta_kernel" },
        "alpha": { "type": "number", "exclusiveMinimum": 0 },
        "beta": { "type": "number", "exclusiveMinimum": 0 },
        "support_radius": { "$ref": "#/$defs/vec3" }
      }
    },
    "gabor_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "frequency", "bandwidth", "phase"],
      "properties": {
        "type": { "const": "gabor_frequency" },
        "frequency": { "$ref": "#/$defs/vec3" },
        "bandwidth": { "type": "number", "exclusiveMinimum": 0 },
        "phase": { "type": "number" },
        "plane_point": { "$ref": "#/$defs/vec3" }
      }
    },
    "neural_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "latent_dim", "residual_scale", "model_ref"],
      "properties": {
        "type": { "const": "neural_residual" },
        "latent_dim": { "type": "integer", "minimum": 1 },
        "residual_scale": { "type": "number", "minimum": 0, "maximum": 1 },
        "model_ref": { "type": ["string", "null"] }
      }
    },
    "gaussian_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "mean", "covariance", "source"],
      "properties": {
        "type": { "const": "gaussian_fallback" },
        "mean": { "$ref": "#/$defs/vec3" },
        "covariance": { "$ref": "#/$defs/matrix3" },
        "source": { "type": "string", "minLength": 1 }
      }
    },
    "semantic_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "label", "confidence", "feature_refs"],
      "properties": {
        "type": { "const": "semantic_feature" },
        "label": { "type": "string", "minLength": 1 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "feature_refs": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
