{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aura.dev/schemas/0.1/exchange.schema.json",
  "title": "AURA Exchange Metadata",
  "type": "object",
  "additionalProperties": false,
  "required": ["asset", "native", "gltfFallback", "usdBridge"],
  "properties": {
    "asset": {
      "type": "string",
      "minLength": 1
    },
    "native": {
      "type": "string",
      "minLength": 1
    },
    "gltfFallback": {
      "$ref": "#/$defs/exchange_target"
    },
    "usdBridge": {
      "$ref": "#/$defs/exchange_target"
    }
  },
  "$defs": {
    "exchange_target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "supports_typed_carriers", "supports_ray_query", "notes"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "supports_typed_carriers": { "type": "boolean" },
        "supports_ray_query": { "type": "boolean" },
        "notes": { "type": "string", "minLength": 1 }
      }
    }
  }
}
