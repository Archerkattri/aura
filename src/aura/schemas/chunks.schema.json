{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aura.dev/schemas/0.1/chunks.schema.json",
  "title": "AURA Chunks",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "id",
      "bounds",
      "element_ids",
      "lod"
    ],
    "properties": {
      "id": {
        "type": "string",
        "minLength": 1
      },
      "bounds": {
        "$ref": "#/$defs/bounds"
      },
      "element_ids": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        },
        "uniqueItems": true
      },
      "lod": {
        "type": "integer",
        "minimum": 0
      }
    }
  },
  "$defs": {
    "vec3": {
      "type": "array",
      "prefixItems": [
        { "type": "number" },
        { "type": "number" },
        { "type": "number" }
      ],
      "items": false,
      "minItems": 3,
      "maxItems": 3
    },
    "bounds": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min", "max"],
      "properties": {
        "min": { "$ref": "#/$defs/vec3" },
        "max": { "$ref": "#/$defs/vec3" }
      }
    }
  }
}
