{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aura.dev/schemas/0.1/manifest.schema.json",
  "title": "AURA Package Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format",
    "version",
    "name",
    "units",
    "coordinateSystem",
    "carrierIds",
    "capabilities",
    "fallbacks",
    "chunks",
    "semanticGraph",
    "exchange"
  ],
  "properties": {
    "format": {
      "const": "AURA"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "units": {
      "type": "string",
      "minLength": 1
    },
    "coordinateSystem": {
      "type": "string",
      "minLength": 1
    },
    "carrierIds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primaryRender",
        "rayQuery",
        "collisionProxy",
        "directRelighting",
        "semanticQuery",
        "neuralResidual"
      ],
      "properties": {
        "primaryRender": { "type": "boolean" },
        "rayQuery": { "type": "boolean" },
        "collisionProxy": { "type": "boolean" },
        "directRelighting": { "type": "boolean" },
        "semanticQuery": { "type": "boolean" },
        "neuralResidual": { "type": "boolean" }
      }
    },
    "fallbacks": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "chunks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "semanticGraph": {
      "const": "semantic_graph.json"
    },
    "exchange": {
      "const": "exchange.json"
    }
  }
}
